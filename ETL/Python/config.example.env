NHL_DW_SQL_SERVER=localhost
NHL_DW_DATABASE=NHLDataWarehouse
NHL_DW_ODBC_DRIVER=ODBC Driver 18 for SQL Server
NHL_DW_TRUSTED_CONNECTION=yes
NHL_DW_TRUST_SERVER_CERTIFICATE=yes
NHL_TEAMS_ENDPOINT=https://api.nhle.com/stats/rest/en/team
NHL_ROSTER_ENDPOINT_TEMPLATE=https://api-web.nhle.com/v1/roster/{team_abbrev}/current
NHL_SCHEDULE_ENDPOINT_TEMPLATE=https://api-web.nhle.com/v1/schedule/{game_date}
NHL_BOXSCORE_ENDPOINT_TEMPLATE=https://api-web.nhle.com/v1/gamecenter/{game_id}/boxscore

# Optional filters for individual ETL runs.
# NHL_TEAM_ABBREVS=TOR,BOS
# NHL_START_DATE=2024-10-04
# NHL_END_DATE=2024-10-10
# NHL_GAME_IDS=2024020001,2024020002

# Optional: use this instead of the individual SQL Server settings above.
# NHL_DW_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=NHLDataWarehouse;Trusted_Connection=yes;TrustServerCertificate=yes;
